# ──────────────────────────────────────────────────────────────────────────────
# WhatsApp AI Assistant — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Base de datos ────────────────────────────────────────────────────────────
# SQLite (default para MVP local):
DATABASE_URL="file:./data/assistant.db"

# PostgreSQL (producción — descomenta y ajusta):
# DATABASE_URL="postgresql://usuario:contraseña@host:5432/whatsapp_assistant?schema=public"

# ─── Proveedor de WhatsApp ────────────────────────────────────────────────────
# Opciones: "whatsapp-api" | "baileys"
WHATSAPP_PROVIDER=whatsapp-api

# WhatsApp Business API (Meta)
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta
WHATSAPP_VERIFY_TOKEN=tu_token_secreto_para_verificacion_webhook

# ─── Proveedor de IA ──────────────────────────────────────────────────────────
# Opciones: "claude" | "rules" (fallback sin IA)
AI_PROVIDER=claude

ANTHROPIC_API_KEY=tu_api_key_de_anthropic
# claude-sonnet-4-5-20250929 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Umbral de confianza (0–1). Por debajo → escala a humano
AI_CONFIDENCE_THRESHOLD=0.65

# ─── Lógica de escalado ───────────────────────────────────────────────────────
# Nº de fallos consecutivos antes de escalar
ESCALATION_FAILURE_LIMIT=3

# ─── Cola de mensajes ─────────────────────────────────────────────────────────
# Opciones: "memory" | "redis"
QUEUE_PROVIDER=memory

# Redis (solo si QUEUE_PROVIDER=redis)
REDIS_URL=redis://localhost:6379

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Token para endpoints internos (health check con datos, admin, etc.)
INTERNAL_API_TOKEN=cambia_esto_por_un_token_seguro

# ─── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
