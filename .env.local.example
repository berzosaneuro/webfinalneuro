# ===========================================
# Variables requeridas para producción
# ===========================================
# En Vercel: Project → Settings → Environment Variables (Production + Preview si aplica).
# No marques como NEXT_PUBLIC_ ninguna clave secreta (Stripe secret, webhook secret, service role).

# --- Supabase (el código usa SOLO estos nombres; no hay SUPABASE_URL sin prefijo) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
# Solo servidor: webhook Stripe y escrituras que bypass RLS. Nunca NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Sesión segura (obligatoria en producción)
APP_SESSION_SECRET=una-clave-larga-aleatoria-32-o-mas-caracteres
ADMIN_PASSWORD=una-clave-admin-segura

# --- Stripe (modo live: sk_live_... y endpoint webhook “live” con su whsec_) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Opcional: publicable si más adelante usas Stripe.js en cliente; el checkout actual es redirect servidor
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# URL canónica con https (evita redirect erróneo tras pago). Ej: https://webfinalneuro.vercel.app o tu dominio
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
# VERCEL_URL lo inyecta Vercel automáticamente (no hace falta definirla a mano)

# Flags de módulos en beta (desactivados por defecto en producción)
NEXT_PUBLIC_ENABLE_AR=false
NEXT_PUBLIC_ENABLE_COMPANERO=false
NEXT_PUBLIC_ENABLE_BIOFEEDBACK=false
NEXT_PUBLIC_ENABLE_EVENTOS=false

# Anthropic (opcional — activa IA real en /ia-coach)
ANTHROPIC_API_KEY=tu-api-key-aqui

# ElevenLabs (opcional — usa tu voz clonada en las meditaciones)
# Obtén API key y Voice ID en https://elevenlabs.io
ELEVENLABS_API_KEY=tu-api-key-elevenlabs
ELEVENLABS_VOICE_ID=tu-voice-id-clonada

# Compat legacy (evitar usar en nuevos despliegues):
# NEXT_PUBLIC_ADMIN_PASSWORD=solo-legacy

# Enlace al grupo de WhatsApp (Comunidad) — En WhatsApp: grupo → Invitar mediante enlace → Copiar enlace
NEXT_PUBLIC_WHATSAPP_GROUP=https://chat.whatsapp.com/TU_CODIGO_DEL_GRUPO

# Email (opcional — activa notificaciones cuando alguien escribe o se apunta)
# Datos SMTP de Dondominio (cPanel): Panel → Email → Cuentas de correo → Ver configuración
EMAIL_SMTP_HOST=mail.berzosaneuro.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=contacto@berzosaneuro.com
EMAIL_SMTP_PASS=tu-contrasena-de-correo
EMAIL_NOTIFY_TO=admin@berzosaneuro.com
