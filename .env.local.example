# ===========================================
# Variables requeridas para producción
# ===========================================

# Supabase - Obtén estos valores en https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Anthropic (opcional — activa IA real en /ia-coach)
ANTHROPIC_API_KEY=tu-api-key-aqui

# ElevenLabs (opcional — usa tu voz clonada en las meditaciones)
# Obtén API key y Voice ID en https://elevenlabs.io
ELEVENLABS_API_KEY=tu-api-key-elevenlabs
ELEVENLABS_VOICE_ID=tu-voice-id-clonada

# Admin (opcional — contraseña del panel admin, por defecto berzosaneuro)
NEXT_PUBLIC_ADMIN_PASSWORD=tu-contrasena-admin

# Enlace al grupo de WhatsApp (Comunidad) — En WhatsApp: grupo → Invitar mediante enlace → Copiar enlace
NEXT_PUBLIC_WHATSAPP_GROUP=https://chat.whatsapp.com/TU_CODIGO_DEL_GRUPO

# Email (opcional — activa notificaciones cuando alguien escribe o se apunta)
# Datos SMTP de Dondominio (cPanel): Panel → Email → Cuentas de correo → Ver configuración
EMAIL_SMTP_HOST=mail.berzosaneuro.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=contacto@berzosaneuro.com
EMAIL_SMTP_PASS=tu-contrasena-de-correo
EMAIL_NOTIFY_TO=admin@berzosaneuro.com
